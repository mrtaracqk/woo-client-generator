# Local WooCommerce fixture base URL.
WOO_BASE_URL=http://127.0.0.1:8081

# Used by snapshot and sync scripts when --base-url is omitted.
WOO_REST_SNAPSHOT_BASE_URL=http://127.0.0.1:8081

# Optional namespace override for snapshot and sync scripts.
# WOO_REST_SNAPSHOT_NAMESPACE=wc/v3

# Used by the fixture sync helper.
WOO_FIXTURE_SITE_URL=http://127.0.0.1:8081

# Optional override. Resolution order is:
# CLI flag -> this env var -> live woocommerce/readme.txt -> unknown.
# WOO_REST_SNAPSHOT_WOO_VERSION=10.5.1

# Optional override for manifest/definitions generators.
# WOO_REST_MANIFEST_INPUT=generated/woo-rest/woo-v10.5.1.snapshot.json
# WOO_REST_OPERATION_DEFINITIONS_INPUT=generated/woo-rest/woo-v10.5.1.manifest.json
